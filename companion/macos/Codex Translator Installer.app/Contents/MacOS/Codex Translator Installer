#!/bin/sh

APP_DIR="$(cd "$(dirname "$0")/../../../../.." && pwd)"
INSTALL_SCRIPT="$APP_DIR/scripts/install-native-host-macos.sh"

if [ ! -x "$INSTALL_SCRIPT" ]; then
  /usr/bin/osascript -e 'display dialog "설치 스크립트를 찾을 수 없습니다. 배포 폴더 전체를 받은 뒤 companion/macos/Codex Translator Installer.app을 실행하세요." buttons {"확인"} default button "확인" with title "Codex Translator" with icon caution'
  exit 1
fi

if OUTPUT="$(CODEX_TRANSLATOR_OPEN_SETUP=1 "$INSTALL_SCRIPT" 2>&1)"; then
  /usr/bin/osascript -e 'display dialog "Native host 설치가 완료되었습니다. 열린 설정 화면에서 다시 확인을 누른 뒤 사용하세요." buttons {"확인"} default button "확인" with title "Codex Translator"'
else
  ESCAPED_OUTPUT="$(printf "%s" "$OUTPUT" | sed 's/\\/\\\\/g; s/"/\\"/g')"
  /usr/bin/osascript -e 'display dialog "Native host 설치에 실패했습니다.\n\n'"$ESCAPED_OUTPUT"'" buttons {"확인"} default button "확인" with title "Codex Translator" with icon caution'
  exit 1
fi
